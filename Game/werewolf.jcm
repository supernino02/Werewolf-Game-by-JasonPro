mas vesna {
    agent narrator : narrator.asl {
        goals  : setup
        beliefs: setting(debug_log(true)),
                 setting(phase_transition_delay_ms(0)), 
                 setting(writing_delay_ms(0)),
                 setting(responsive_delay_range_ms(500,1000)),

                 //setting(llm_disabled(true)),
                 setting(ui_show_vote_recap(false)),
                 setting(ui_show_hunt_recap(false)),
                 setting(ui_show_intent_to_speak_recap(false)),

                 setting(avoid_ties_in_votes(true)),
                 setting(debug_log(true)),
                 setting(llm_model("gemma4:e4b"))
    }

    // ==========================================
    // --- THE WOLF PACK (12 Players) ---
    // ==========================================

    // 1. The Mastermind Wolf (Calm and controlling)
    agent alice : init_player.asl {
        instances : 1
        ag-class: vesna.ProAgent
        temper: temper( paranoia(-0.8), individualism(0.9), stress(0)[mood], exposure(0)[mood] )
        strategy: most_similar
        beliefs: iam(wolf), reasoner(llm), setting(spectator_mode(true))
    }

    // 2. The Sheep Wolf (Blends in, follows others)
    agent bob : init_player.asl {
        instances : 1
        ag-class: vesna.ProAgent
        temper: temper( paranoia(0.4), individualism(-0.7), stress(0)[mood], exposure(-1)[mood] )
        strategy: most_similar
        beliefs: iam(wolf), reasoner(llm)
    }

    // 3. The Hysteric Wolf (A liability, overly defensive)
    agent charlie : init_player.asl {
        instances : 1
        ag-class: vesna.ProAgent
        temper: temper( paranoia(0.9), individualism(-0.8), stress(1)[mood], exposure(-0.5)[mood] )
        strategy: most_similar
        beliefs: iam(wolf), reasoner(llm)
    }

    // ==========================================
    // --- THE VILLAGE (9 Players) ---
    // ==========================================
// 1. The Gullible Sheep (Lowest Paranoia, Lowest Individualism)
