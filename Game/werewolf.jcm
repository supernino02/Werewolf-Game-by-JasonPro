    agent arthur : init_player.asl {
        instances: 1
        ag-class: vesna.ProAgent
        temper: temper( paranoia(-1.0), individualism(-1.0), stress(-0.5)[mood], exposure(0.0)[mood] )
        strategy: most_similar
        beliefs: iam(villager), reasoner(llm)//, setting(spectator_mode(true))
    }

