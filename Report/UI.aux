\newlabel{lst:human_vote_hook}{{11}{30}{Example of a UI execution hook. Once notified the start of the hunting phase the ui is updated to allow the voting; the Agent's intention to choose a target halts using \texttt {.wait} and resumes immediately once the human interaction injects the \texttt {user\_input} belief}{lstlisting.11}{}}
\@writefile{lol}{\contentsline {lstlisting}{\numberline {11}{\ignorespaces Example of a UI execution hook. Once notified the start of the hunting phase the ui is updated to allow the voting; the Agent's intention to choose a target halts using \texttt  {.wait} and resumes immediately once the human interaction injects the \texttt  {user\_input} belief.}}{30}{lstlisting.11}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Dashboard Layout and Visualizer}{30}{subsection.5.2}\protected@file@percent }
